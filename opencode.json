{
  "$schema": "https://opencode.ai/config.json",
  "model": "opencode-go/glm-5.2",
  "provider": {
    "progrok": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Grok (progrok)",
      "options": {
        "baseURL": "http://127.0.0.1:18645/v1",
        "apiKey": "anything"
      },
      "models": {
        "grok-composer-2.5-fast": {
          "name": "Grok Composer 2.5 Fast"
        },
        "grok-4.3": {
          "name": "Grok 4.3",
          "attachment": true,
          "modalities": {
            "input": ["text", "image"]
          },
          "tool_call": true,
          "limit": {
            "context": 1000000,
            "output": 16384
          }
        }
      }
    }
  },
  "agent": {
    "explore": {
      "model": "progrok/grok-composer-2.5-fast"
    }
  }
}