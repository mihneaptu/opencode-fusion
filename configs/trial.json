{
  "$schema": "https://opencode.ai/config.json",
  "model": "kiro/claude-opus-4-8",
  "provider": {
    "progrok": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Grok Composer 2.5 Fast (progrok)",
      "options": {
        "baseURL": "http://127.0.0.1:18645/v1",
        "apiKey": "anything"
      },
      "models": {
        "grok-composer-2.5-fast": {
          "name": "Grok Composer 2.5 Fast"
        }
      }
    },
    "kiro": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Kiro Gateway (Claude)",
      "options": {
        "baseURL": "http://127.0.0.1:9000/v1",
        "apiKey": "kiro-local-proxy-key"
      },
      "models": {
        "claude-opus-4-8": {
          "name": "Opus 4.8",
          "attachment": true,
          "modalities": {
            "input": ["text", "image"]
          }
        },
        "claude-sonnet-5": {
          "name": "Sonnet 5"
        }
      }
    }
  },
  "agent": {
    "build": {
      "mode": "primary",
      "model": "kiro/claude-opus-4-8",
      "prompt": "{file:agent/build.md}",
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "deny",
          "npm run lint*": "allow",
          "npm test*": "allow",
          "npm run build*": "allow",
          "npx tsc --noEmit*": "allow",
          "npx vitest run*": "allow",
          "git diff*": "allow",
          "git status*": "allow",
          "git log*": "allow",
          "git show*": "allow",
          "git add*": "allow",
          "git commit*": "allow",
          "git push*": "allow",
          "node --version*": "allow",
          "npm --version*": "allow"
        },
        "task": "allow"
      }
    },
    "explore": {
      "model": "progrok/grok-composer-2.5-fast"
    },
    "sidekick": {
      "model": "kiro/claude-sonnet-5"
    }
  }
}
