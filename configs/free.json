{
  "$schema": "https://opencode.ai/config.json",
  "model": "opencode-go/glm-5.2",
  "provider": {
    "opencode": {
      "models": {
        "deepseek-v4-flash-free": { "name": "DeepSeek V4 Flash Free" }
      }
    }
  },
  "agent": {
    "build": {
      "model": "opencode-go/glm-5.2",
      "prompt": "{file:agent/build.md}",
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "deny",
          "npm run lint*": "allow",
          "npm test*": "allow",
          "npm run build*": "allow",
          "npx tsc --noEmit*": "allow",
          "npx vitest run*": "allow",
          "git diff*": "allow",
          "git status*": "allow",
          "git log*": "allow",
          "git show*": "allow",
          "git add*": "allow",
          "git commit*": "allow",
          "git push*": "allow",
          "node --version*": "allow",
          "npm --version*": "allow"
        },
        "task": "allow"
      }
    },
    "explore": { "model": "opencode/deepseek-v4-flash-free" },
    "sidekick": { "model": "opencode/deepseek-v4-flash-free" }
  }
}