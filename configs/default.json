{
  "$schema": "https://opencode.ai/config.json",
  "model": "opencode-go/glm-5.2",
  "provider": {
    "progrok": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Grok (progrok)",
      "options": {
        "baseURL": "http://127.0.0.1:18645/v1",
        "apiKey": "anything"
      },
      "models": {
        "grok-composer-2.5-fast": { "name": "Grok Composer 2.5 Fast" },
        "grok-4.3": {
          "name": "Grok 4.3",
          "attachment": true,
          "modalities": { "input": ["text", "image"] },
          "tool_call": true,
          "limit": { "context": 1000000, "output": 16384 }
        }
      }
    }
  },
  "agent": {
    "build": {
      "model": "opencode-go/glm-5.2",
      "prompt": "{file:agent/build.md}",
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "deny",
          "npm run lint*": "allow",
          "npm test*": "allow",
          "npm run build*": "allow",
          "npx tsc --noEmit*": "allow",
          "npx vitest run*": "allow",
          "git diff*": "allow",
          "git status*": "allow",
          "git log*": "allow",
          "git show*": "allow",
          "git add*": "allow",
          "git commit*": "allow",
          "git push*": "allow",
          "node --version*": "allow",
          "npm --version*": "allow"
        },
        "task": "allow"
      }
    },
    "explore": { "model": "progrok/grok-composer-2.5-fast" },
    "sidekick": { "model": "progrok/grok-composer-2.5-fast" },
    "vision": { "model": "progrok/grok-4.3" }
  }
}